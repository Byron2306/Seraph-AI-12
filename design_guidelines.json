    "icons": {
      "library": "lucide-react",
      "style": "Stroke width 1.5px, sharp or rounded depending on context."
    }
  },
  "implementation_instructions": {
    "packages_to_install": [
      "framer-motion",
      "recharts",
      "clsx",
      "tailwind-merge",
      "lucide-react",
      "tsparticles",
      "@tsparticles/react",
      "@tsparticles/slim"
    ],
    "steps": [
      "1. Install required packages.",
      "2. Update tailwind.config.js with the defined color palette and fonts.",
      "3. Create a 'Layout' component that enforces the dark theme and background texture.",
      "4. Build the 'Dashboard' using the Bento Grid strategy.",
      "5. Implement 'AI Detection Engine' with real-time charts (Recharts).",
      "6. Use 'framer-motion' for smooth transitions between states."
    ],
    "universal_guidelines": [
      "DO NOT use gradients for text unless it's a very large headline.",
      "Ensure all text has sufficient contrast (APCA standards).",
      "Use 'data-testid' for all interactive elements.",
      "Avoid 'AI Slop' - no generic centered layouts. Use asymmetry.",
      "Use 'sonner' for notifications."
    ]
  }
}